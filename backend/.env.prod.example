# 生产环境示例配置（复制为 backend/.env.prod 使用；不要提交真实密钥）

# ── App ──────────────────────────────────────────────────
APP_ENV=production
DEBUG=false

# ── Database (Supabase Postgres，当前代码基本未使用，可先填好占位) ─────
# DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/postgres
DATABASE_URL=

# ── Redis (Vercel KV / Upstash Redis) ─────────────────────
# REDIS_URL=redis://default:<password>@<host>:<port>
# 或 rediss://...（TLS）
REDIS_URL=

# ── LLM Providers (填入你的 keys) ─────────────────────────
LLM_PRIMARY_BASE_URL=https://grok.showqr.eu.cc/v1
LLM_PRIMARY_API_KEY=
LLM_PRIMARY_MODEL=grok-4.1-fast
LLM_PRIMARY_FALLBACK_MODELS=
LLM_PRIMARY_TIMEOUT=15
LLM_PRIMARY_REASONING_EFFORT=
LLM_PRIMARY_MAX_COMPLETION_TOKENS=0
LLM_PRIMARY_MAX_LEGS=6
LLM_PRIMARY_MAX_TIPS_PER_LEG=1

LLM_BACKUP1_BASE_URL=https://openai.showqr.eu.cc/v1
LLM_BACKUP1_API_KEY=
LLM_BACKUP1_MODEL=MiniMax-M2.5
LLM_BACKUP1_FALLBACK_MODELS=gpt-5.2
LLM_BACKUP1_TIMEOUT=15

LLM_BACKUP2_BASE_URL=https://api.siliconflow.cn/v1
LLM_BACKUP2_API_KEY=
LLM_BACKUP2_MODEL=Qwen/Qwen2.5-7B-Instruct
LLM_BACKUP2_FALLBACK_MODELS=
LLM_BACKUP2_TIMEOUT=15

# ── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_ANONYMOUS=200
RATE_LIMIT_AUTHENTICATED=500

# ── Google ───────────────────────────────────────────────
GOOGLE_GEOCODING_API_KEY=
