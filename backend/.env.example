# ── App ──────────────────────────────────────────────────
APP_ENV=local
DEBUG=true

# ── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/hacktravel

# ── Redis ────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── LLM Providers (fill in your keys) ───────────────────
LLM_PRIMARY_BASE_URL=http://openai.showqr.eu.cc/v1
LLM_PRIMARY_API_KEY=
LLM_PRIMARY_MODEL=gpt-5.4

LLM_BACKUP1_BASE_URL=https://api.siliconflow.cn/v1
LLM_BACKUP1_API_KEY=
LLM_BACKUP1_MODEL=deepseek-ai/DeepSeek-V3

LLM_BACKUP2_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_BACKUP2_API_KEY=
LLM_BACKUP2_MODEL=meta/llama-3.1-70b-instruct

# ── Google ───────────────────────────────────────────────
GOOGLE_GEOCODING_API_KEY=
