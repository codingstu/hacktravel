# ── App ──────────────────────────────────────────────────
APP_ENV=local
DEBUG=true

# ── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/hacktravel

# ── Redis ────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── LLM Providers (fill in your keys) ───────────────────
# Root cause of showqr slowness is not network/TLS, but oversized prompt + output generation.
# Use low reasoning effort and tighter output constraints on the primary route.
LLM_PRIMARY_BASE_URL=https://openai.showqr.eu.cc/v1
LLM_PRIMARY_API_KEY=
LLM_PRIMARY_MODEL=gpt-5.4
LLM_PRIMARY_FALLBACK_MODELS=
LLM_PRIMARY_TIMEOUT=45
LLM_PRIMARY_REASONING_EFFORT=low
LLM_PRIMARY_MAX_COMPLETION_TOKENS=900
LLM_PRIMARY_MAX_LEGS=8
LLM_PRIMARY_MAX_TIPS_PER_LEG=2

# First backup: NVIDIA NIM (preferred external provider)
LLM_BACKUP1_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_BACKUP1_API_KEY=
LLM_BACKUP1_MODEL=meta/llama-3.1-70b-instruct
LLM_BACKUP1_FALLBACK_MODELS=nvidia/nemotron-4-340b-instruct
LLM_BACKUP1_TIMEOUT=22

# Second backup: SiliconFlow (avoid DeepSeek reasoning model first for latency)
LLM_BACKUP2_BASE_URL=https://api.siliconflow.cn/v1
LLM_BACKUP2_API_KEY=
LLM_BACKUP2_MODEL=Qwen/Qwen2.5-72B-Instruct
LLM_BACKUP2_FALLBACK_MODELS=deepseek-ai/DeepSeek-V3,deepseek-ai/DeepSeek-R1
LLM_BACKUP2_TIMEOUT=28

# ── Google ───────────────────────────────────────────────
GOOGLE_GEOCODING_API_KEY=
