# ── App ──────────────────────────────────────────────────
APP_ENV=local
DEBUG=true

# ── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/hacktravel

# ── Redis ────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── LLM Providers (fill in your keys) ───────────────────
# Primary: ShowQR gateway — tested models with auto-failover
# qwen3-235b (~17s, most concise) → deepseek-v3.1 (~25s) → deepseek-v3.2 (~25s)
LLM_PRIMARY_BASE_URL=https://openai.showqr.eu.cc/v1
LLM_PRIMARY_API_KEY=
LLM_PRIMARY_MODEL=qwen3-235b-a22b-instruct
LLM_PRIMARY_FALLBACK_MODELS=deepseek-v3.1,deepseek-v3.2
LLM_PRIMARY_TIMEOUT=35
LLM_PRIMARY_REASONING_EFFORT=
LLM_PRIMARY_MAX_COMPLETION_TOKENS=0
LLM_PRIMARY_MAX_LEGS=6
LLM_PRIMARY_MAX_TIPS_PER_LEG=1

# First backup: SiliconFlow (保底 — reliable domestic provider)
LLM_BACKUP1_BASE_URL=https://api.siliconflow.cn/v1
LLM_BACKUP1_API_KEY=
LLM_BACKUP1_MODEL=Qwen/Qwen2.5-72B-Instruct
LLM_BACKUP1_FALLBACK_MODELS=deepseek-ai/DeepSeek-V3,deepseek-ai/DeepSeek-R1
LLM_BACKUP1_TIMEOUT=30

# Second backup: NVIDIA NIM (last resort)
LLM_BACKUP2_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_BACKUP2_API_KEY=
LLM_BACKUP2_MODEL=z-ai/glm4.7
LLM_BACKUP2_FALLBACK_MODELS=
LLM_BACKUP2_TIMEOUT=35

# ── Google ───────────────────────────────────────────────
GOOGLE_GEOCODING_API_KEY=
