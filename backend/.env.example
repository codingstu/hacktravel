# ── App ──────────────────────────────────────────────────
APP_ENV=local
DEBUG=true

# ── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/hacktravel

# ── Redis ────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── LLM Providers (fill in your keys) ───────────────────
# Primary: ShowQR Grok gateway — grok-4.1-fast, grok-4.1-thinking fallback
# 超时策略: 主25s + 备25s = 50s < 前端60s
LLM_PRIMARY_BASE_URL=https://grok.showqr.eu.cc/v1
LLM_PRIMARY_API_KEY=
LLM_PRIMARY_MODEL=grok-4.1-fast
LLM_PRIMARY_FALLBACK_MODELS=
LLM_PRIMARY_TIMEOUT=15
LLM_PRIMARY_REASONING_EFFORT=
LLM_PRIMARY_MAX_COMPLETION_TOKENS=0
LLM_PRIMARY_MAX_LEGS=6
LLM_PRIMARY_MAX_TIPS_PER_LEG=1

# First backup: ShowQR OpenAI gateway — gpt-5.2 fallback
LLM_BACKUP1_BASE_URL=https://openai.showqr.eu.cc/v1
LLM_BACKUP1_API_KEY=
LLM_BACKUP1_MODEL=gpt-5.2
LLM_BACKUP1_FALLBACK_MODELS=
LLM_BACKUP1_TIMEOUT=15

# Second backup: SiliconFlow (保底 — reliable domestic provider)
LLM_BACKUP2_BASE_URL=https://api.siliconflow.cn/v1
LLM_BACKUP2_API_KEY=
LLM_BACKUP2_MODEL=Qwen/Qwen2.5-7B-Instruct
LLM_BACKUP2_FALLBACK_MODELS=
LLM_BACKUP2_TIMEOUT=15

# ── Google ───────────────────────────────────────────────
GOOGLE_GEOCODING_API_KEY=
